# Braille rendering — each terminal cell encodes a 2×4 dot grid.
# Bit layout (Unicode braille standard):
#   col→  0     1
# row 0:  0x01  0x08
# row 1:  0x02  0x10
# row 2:  0x04  0x20
# row 3:  0x40  0x80
BRAILLE_BASE = 0x2800
