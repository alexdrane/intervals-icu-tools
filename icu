def load_config():
    if not os.path.exists(CONFIG_FILE):
        console.print("[red]No config found.[/] Run with --setup to configure.", highlight=False)
        sys.exit(1)
    with open(CONFIG_FILE) as f:
        return json.load(f)


def setup():
    console.print("\n[bold]intervals.icu setup[/]\n")
    console.print("Find your athlete ID in the URL when logged in: intervals.icu/athletes/[bold]i12345[/]")
    console.print("Find your API key at: Settings → Developer Settings → API Key\n")
    athlete_id = input("Athlete ID (e.g. i12345): ").strip()
