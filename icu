def fetch_activities(athlete_id, api_key, count=15):
    oldest = (datetime.now() - timedelta(days=365)).strftime("%Y-%m-%dT00:00:00")
    newest = datetime.now().strftime("%Y-%m-%dT23:59:59")
    url = f"{BASE_URL}/athlete/{athlete_id}/activities"
    params = {"oldest": oldest, "newest": newest}
    resp = requests.get(url, params=params, auth=("API_KEY", api_key), timeout=10)
    resp.raise_for_status()
    activities = resp.json()
    # Sort by date ascending, take most recent N, reverse for display (newest first)
    activities.sort(key=lambda a: a.get("start_date_local") or a.get("start_date") or "")
    return activities[-count:][::-1]


def fetch_activities_range(athlete_id, api_key, oldest, newest):
    url = f"{BASE_URL}/athlete/{athlete_id}/activities"
    params = {"oldest": oldest.strftime("%Y-%m-%dT00:00:00"),
              "newest": newest.strftime("%Y-%m-%dT23:59:59")}
    resp = requests.get(url, params=params, auth=("API_KEY", api_key), timeout=10)
    resp.raise_for_status()
    activities = resp.json()
    activities.sort(key=lambda a: a.get("start_date_local") or a.get("start_date") or "")
    return activities



def compute_hi_load(activities, days, tau=14):
    """Exponentially weighted Z4+ rowing minutes with decay constant τ days.

    Analogous to CTL but specific to high-intensity rowing load. Decays ~3×
    faster than CTL (τ=14 vs 42) reflecting the shorter half-life of anaerobic
    and lactate-threshold adaptations.
    """
    decay = math.exp(-1 / tau)
    accumulate = 1 - decay

    hi_by_date = defaultdict(float)
    for a in activities:
        if "Row" not in a.get("type", ""):
            continue
        date_str = (a.get("start_date_local") or a.get("start_date") or "")[:10]
        if not date_str:
            continue
        zone_times = a.get("icu_hr_zone_times") or []
        hi_secs = sum(zone_times[i] for i in range(3, min(7, len(zone_times))))
        hi_by_date[date_str] += hi_secs / 60

    start = datetime.now() - timedelta(days=days)
    dates, hil = [], []
    current = 0.0
    d = start
    while d.date() <= datetime.now().date():
        date_str = d.strftime("%Y-%m-%d")
        current = current * decay + hi_by_date.get(date_str, 0.0) * accumulate
        dates.append(d)
        hil.append(round(current, 2))
        d += timedelta(days=1)

    return dates, hil


MIN_ROWING_VELOCITY = 500 / 180  # 3:00/500m split in m/s — below this with Z1 HR is excluded


def fetch_active_zone_times(activity_id, api_key, hr_zones):
    """Return per-zone seconds, excluding slow + Z1 time (traffic, drifting, spinning).

    A second is excluded only if BOTH conditions hold:
      - velocity < MIN_ROWING_VELOCITY (slower than 3:00/500m)
      - HR is in Z1 (not working hard enough to count regardless of speed)
    This keeps elevated-HR rest periods between pieces (e.g. floating after a 500m).
    """
    url = f"{BASE_URL}/activity/{activity_id}/streams"
    resp = requests.get(url, params={"types": "heartrate,velocity_smooth"},
                        auth=("API_KEY", api_key), timeout=15)
    resp.raise_for_status()
    streams = {s["type"]: s["data"] for s in resp.json()}
    hr_data = streams.get("heartrate") or []
    vel_data = streams.get("velocity_smooth") or []
    if not hr_data or not vel_data:
        return None
    boundaries = hr_zones[:-1]  # e.g. [141, 156, 164, 174, 179, 184]
    zone_times = [0] * 7
    for hr, vel in zip(hr_data, vel_data):
        if hr is None or vel is None:
            continue
        z = bisect_left(boundaries, hr)
        if vel < MIN_ROWING_VELOCITY and z == 0:
            continue  # slow AND Z1 — traffic / drift
        if z < 7:
            zone_times[z] += 1
    return zone_times


def fetch_wellness(athlete_id, api_key, days=90):
    oldest = (datetime.now() - timedelta(days=days)).strftime("%Y-%m-%d")
    newest = datetime.now().strftime("%Y-%m-%d")
    url = f"{BASE_URL}/athlete/{athlete_id}/wellness"
    params = {"oldest": oldest, "newest": newest}
    resp = requests.get(url, params=params, auth=("API_KEY", api_key), timeout=10)
    resp.raise_for_status()
    return resp.json()


def fmt_duration(seconds):
    if not seconds:
        return "—"
    h, m = divmod(int(seconds) // 60, 60)
    if h:
        return f"{h}h {m:02d}m"
    return f"{m}m"


def fmt_distance(meters):
    if not meters:
        return "—"
    km = meters / 1000
    if km >= 10:
        return f"{km:.1f} km"
    return f"{km:.2f} km"


def fmt_load(activity):
    for key in ("icu_training_load", "load", "training_load", "tss"):
        val = activity.get(key)
        if val:
            return str(int(val))
    return "—"


def fmt_zones(zone_times):
    """zone_times: list of seconds per zone from icu_hr_zone_times (index 0 = Z1)."""
    if not zone_times:
        return Text("—", style="dim")
    parts = [(i + 1, t // 60) for i, t in enumerate(zone_times) if t // 60 > 0]
    if not parts:
        return Text("—", style="dim")
    result = Text()
    for i, (z, mins) in enumerate(parts):
        if i > 0:
            result.append(" ", style="dim")
        result.append(f"Z{z}:", style="dim")
        result.append(f"{mins}m", style=ZONE_COLORS.get(z, "white"))
    return result


def fmt_date(date_str):
    if not date_str:
        return "—"
    try:
        dt = datetime.fromisoformat(date_str.replace("Z", "+00:00"))
        return dt.strftime("%a %d %b")
    except Exception:
        return date_str[:10]


def show_activities(activities, show_zones=False):
    table = Table(
        box=box.ROUNDED,
        show_header=True,
        header_style="bold white",
        border_style="dim",
        expand=False,
    )
    table.add_column("Date", style="dim", min_width=10)
    table.add_column("Activity", min_width=20, max_width=35)
    table.add_column("Type", min_width=8)
    table.add_column("Duration", justify="right", min_width=8)
    table.add_column("Distance", justify="right", min_width=9)
    table.add_column("Load", justify="right", min_width=5)
    if show_zones:
        table.add_column("Zones", min_width=18)

    for act in activities:
        sport = act.get("type", "Workout")
        color = SPORT_COLORS.get(sport, "white")
        name = act.get("name") or sport
        desc = act.get("description")
        name_cell = Text(name, overflow="ellipsis")
        if desc:
            name_cell.append(f"\n{desc}", style="dim")
        row = [
            fmt_date(act.get("start_date_local") or act.get("start_date")),
            name_cell,
            Text(sport, style=color),
            fmt_duration(act.get("moving_time") or act.get("elapsed_time")),
            fmt_distance(act.get("distance")),
            fmt_load(act),
